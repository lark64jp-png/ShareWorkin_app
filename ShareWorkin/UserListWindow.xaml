<Window x:Class="ShareWorkin.UserListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ユーザー一覧"
        Height="545"
        Width="720"
        WindowStartupLocation="CenterOwner"
        Background="#FFFEFA"
        FontFamily="Yu Gothic UI">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="6" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
            <RowDefinition Height="4" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="ユーザー一覧"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="#2F2A22" />
        <TextBlock Grid.Row="2"
                   Text="つながらない登録済みお友達と、まだ登録していない PC を表示します。行をダブルクリックで開きます。"
                   FontSize="12"
                   Foreground="#4B5563"
                   TextWrapping="Wrap" />

        <Border Grid.Row="4"
                BorderBrush="#D8D2C3"
                BorderThickness="1"
                CornerRadius="6"
                Background="White">
            <ListView x:Name="UserListView"
                      BorderThickness="0"
                      HorizontalContentAlignment="Stretch"
                      MouseDoubleClick="UserListView_MouseDoubleClick"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemContainerStyle>
                    <Style TargetType="{x:Type ListViewItem}">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="6,4" />
                        <Setter Property="Background" Value="{Binding RowBackground}" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="54" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="28"
                                    Height="28"
                                    Background="{Binding IconBrush}"
                                    CornerRadius="3">
                                <Image Source="{Binding IconImage}"
                                       Stretch="Uniform" />
                            </Border>

                            <TextBlock Grid.Column="2"
                                       Text="{Binding NameLabel}"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="{Binding NameWeight}"
                                       FontStyle="{Binding NameStyle}"
                                       Foreground="{Binding NameForeground}"
                                       TextTrimming="CharacterEllipsis" />

                            <TextBlock Grid.Column="4"
                                       Text="{Binding StatusLabel}"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="#3F3A32"
                                       TextTrimming="CharacterEllipsis" />

                            <TextBlock Grid.Column="6"
                                       Text="{Binding ShareFolderName}"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="#3F3A32"
                                       TextTrimming="CharacterEllipsis" />

                            <TextBlock Grid.Column="8"
                                       Text="{Binding Memo}"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="#6B6358"
                                       TextTrimming="CharacterEllipsis" />

                            <TextBlock Grid.Column="10"
                                       Text="{Binding IpLabel}"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="#6B6358"
                                       HorizontalAlignment="Right" />

                            <Button Grid.Column="12"
                                    Content="再開"
                                    Tag="{Binding}"
                                    Height="24"
                                    Padding="6,0"
                                    FontSize="11"
                                    Visibility="{Binding ResumeButtonVisibility}"
                                    Click="ResumeButton_Click" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <!-- 読み込みインジケーター -->
        <ProgressBar Grid.Row="6"
                     x:Name="LoadingBar"
                     Height="3"
                     IsIndeterminate="True"
                     Foreground="#4A7C59"
                     Background="Transparent"
                     BorderThickness="0"
                     Visibility="Collapsed" />

        <StackPanel Grid.Row="8">
            <DockPanel LastChildFill="True">
                <UniformGrid DockPanel.Dock="Right"
                             Rows="1" Columns="3"
                             Width="320">
                    <ComboBox x:Name="ScanModeComboBox"
                              Height="32"
                              Margin="4,0,0,0"
                              VerticalContentAlignment="Center"
                              SelectedIndex="0">
                        <ComboBoxItem Content="接続可能スキャン" />
                        <ComboBoxItem Content="全PCスキャン" />
                    </ComboBox>
                    <Button x:Name="ReloadButton"
                            Content="再スキャン"
                            Height="32"
                            Margin="4,0,0,0"
                            Click="ReloadButton_Click" />
                    <Button Content="閉じる"
                            Height="32"
                            Margin="4,0,0,0"
                            IsCancel="True"
                            Click="CloseButton_Click" />
                </UniformGrid>
                <TextBlock x:Name="ScanStateTextBlock"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="#4B5563"
                           Margin="0,0,8,0" />
            </DockPanel>
            <TextBlock x:Name="StatusTextBlock"
                       Margin="0,3,0,0"
                       FontSize="12"
                       Foreground="#4B5563"
                       TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</Window>
