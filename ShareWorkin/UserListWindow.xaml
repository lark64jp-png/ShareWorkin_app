<Window x:Class="ShareWorkin.UserListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ユーザー一覧"
        Height="520"
        Width="720"
        WindowStartupLocation="CenterOwner"
        Background="#FFFEFA"
        FontFamily="Yu Gothic UI">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="6" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="ユーザー一覧"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="#2F2A22" />
        <TextBlock Grid.Row="2"
                   Text="つながらない登録済みお友達と、まだ登録していない PC を表示します。行をダブルクリックで開きます。"
                   FontSize="12"
                   Foreground="#4B5563"
                   TextWrapping="Wrap" />

        <Border Grid.Row="4"
                BorderBrush="#D8D2C3"
                BorderThickness="1"
                CornerRadius="6"
                Background="White">
            <ListView x:Name="UserListView"
                      BorderThickness="0"
                      HorizontalContentAlignment="Stretch"
                      MouseDoubleClick="UserListView_MouseDoubleClick"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemContainerStyle>
                    <Style TargetType="{x:Type ListViewItem}">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="6,4" />
                        <Setter Property="Background" Value="{Binding RowBackground}" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="28"
                                    Height="28"
                                    Background="{Binding IconBrush}"
                                    CornerRadius="3" />

                            <TextBlock Grid.Column="2"
                                       Text="{Binding NameLabel}"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="{Binding NameWeight}"
                                       FontStyle="{Binding NameStyle}"
                                       Foreground="{Binding NameForeground}"
                                       TextTrimming="CharacterEllipsis" />

                            <TextBlock Grid.Column="4"
                                       Text="{Binding ShareFolderName}"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="#3F3A32"
                                       TextTrimming="CharacterEllipsis" />

                            <TextBlock Grid.Column="6"
                                       Text="{Binding Memo}"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="#6B6358"
                                       TextTrimming="CharacterEllipsis" />

                            <TextBlock Grid.Column="8"
                                       Text="{Binding IpLabel}"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="#6B6358"
                                       HorizontalAlignment="Right" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusTextBlock"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="#4B5563" />

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal">
                <Button Content="再読み込み"
                        Width="100"
                        Height="32"
                        Margin="0,0,8,0"
                        Click="ReloadButton_Click" />
                <Button Content="閉じる"
                        Width="84"
                        Height="32"
                        IsCancel="True"
                        Click="CloseButton_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
