<Window x:Class="ShareWorkin.NetworkHealthGuideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定確認"
        Height="560"
        Width="760"
        MinHeight="500"
        MinWidth="680"
        WindowStartupLocation="CenterOwner"
        Background="#FFFEFA"
        FontFamily="Yu Gothic UI">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="接続状態の確認"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="#2F2A22" />

        <TextBlock Grid.Row="2"
                   x:Name="SummaryTextBlock"
                   FontSize="12"
                   Foreground="#4B5563"
                   TextWrapping="Wrap" />

        <ScrollViewer Grid.Row="4"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="#FFF8D9"
                        BorderBrush="#E8C66A"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,10">
                    <StackPanel>
                        <TextBlock x:Name="AlertTitleTextBlock"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#8A5A00"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="AlertDetailTextBlock"
                                   Margin="0,4,0,0"
                                   FontSize="12"
                                   Foreground="#8A5A00"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border x:Name="InboundGuideBorder"
                        Margin="0,12,0,0"
                        Background="White"
                        BorderBrush="#D8D2C3"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14,12">
                    <StackPanel>
                        <TextBlock Text="相手からこのPCを見つけにくいとき"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#2F2A22" />
                        <TextBlock x:Name="InboundGuideTextBlock"
                                   Margin="0,6,0,0"
                                   FontSize="12"
                                   Foreground="#4B5563"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="影響しやすい設定"
                                   Margin="0,10,0,0"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#2F2A22" />
                        <TextBlock Text="・ファイアウォールで ShareWorkin の受信が止まっている"
                                   Margin="0,6,0,0"
                                   FontSize="12"
                                   Foreground="#4B5563"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="・Wi-Fi 切替や省電力で UDP 応答が間欠的になっている"
                                   Margin="0,4,0,0"
                                   FontSize="12"
                                   Foreground="#4B5563"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="・共有を開いた直後で、相手からの再探索待ちになっている"
                                   Margin="0,4,0,0"
                                   FontSize="12"
                                   Foreground="#4B5563"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border x:Name="OutboundGuideBorder"
                        Margin="0,12,0,0"
                        Background="White"
                        BorderBrush="#D8D2C3"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14,12">
                    <StackPanel>
                        <TextBlock Text="このPCから相手を見つけにくいとき"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#2F2A22" />
                        <TextBlock x:Name="OutboundGuideTextBlock"
                                   Margin="0,6,0,0"
                                   FontSize="12"
                                   Foreground="#4B5563"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="影響しやすい設定"
                                   Margin="0,10,0,0"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#2F2A22" />
                        <TextBlock Text="・Wi-Fi のネットワーク切替や隔離設定でブロードキャストが届きにくい"
                                   Margin="0,6,0,0"
                                   FontSize="12"
                                   Foreground="#4B5563"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="・ネットワーク プロファイルやファイアウォールで探索応答を受けにくい"
                                   Margin="0,4,0,0"
                                   FontSize="12"
                                   Foreground="#4B5563"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="・相手側が共有を閉じた直後か、起動直後でまだ応答待ちになっている"
                                   Margin="0,4,0,0"
                                   FontSize="12"
                                   Foreground="#4B5563"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <DockPanel Grid.Row="6"
                   LastChildFill="False">
            <WrapPanel DockPanel.Dock="Left">
                <Button Content="ネットワーク設定を開く"
                        Width="150"
                        Height="30"
                        Margin="0,0,10,0"
                        Click="OpenNetworkSettingsButton_Click" />
                <Button Content="ファイアウォールを開く"
                        Width="150"
                        Height="30"
                        Margin="0,0,10,0"
                        Click="OpenFirewallSettingsButton_Click" />
                <Button Content="電源設定を開く"
                        Width="130"
                        Height="30"
                        Click="OpenPowerSettingsButton_Click" />
            </WrapPanel>
            <Button DockPanel.Dock="Right"
                    Content="閉じる"
                    Width="90"
                    Height="30"
                    IsCancel="True"
                    Click="CloseButton_Click" />
        </DockPanel>
    </Grid>
</Window>
