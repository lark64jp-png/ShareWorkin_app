<Window x:Class="ShareWorkin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ShareWorkin"
        Height="600"
        Width="920"
        MinHeight="420"
        MinWidth="680"
        Background="#F6F4EE"
        FontFamily="Yu Gothic UI"
        Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="ShopColumnHeaderStyle" TargetType="{x:Type GridViewColumnHeader}">
            <Setter Property="Background" Value="#F1EFE8" />
            <Setter Property="BorderBrush" Value="#D8D2C3" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="#3F3A32" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E5DFD1" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="IconButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#D8D2C3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#3F3A32" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#F1EFE8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#E5DFD1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ShopListViewItemStyle" TargetType="{x:Type ListViewItem}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="1" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FBFAF6" />
                    <Setter Property="BorderBrush" Value="#E8E1D2" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E7F3EE" />
                    <Setter Property="BorderBrush" Value="#9FCDBD" />
                    <Setter Property="Foreground" Value="#1F2D28" />
                </Trigger>
                <DataTrigger Binding="{Binding IsDropTarget}" Value="True">
                    <Setter Property="Background" Value="#FFF6E2" />
                    <Setter Property="BorderBrush" Value="#F4D898" />
                    <Setter Property="Foreground" Value="#111827" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- TODO_UI: Move the visual language away from a Windows share manager
             and toward a small shop surface. This pass is intentionally light. -->
        <Border Grid.Row="0" Background="#315C50" Padding="28,22">
            <StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                    <TextBlock Text="ShareWorkin"
                               Foreground="White"
                               FontSize="28"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="AppVersionTextBlock"
                               Foreground="#B0D4C0"
                               FontSize="13"
                               Margin="10,0,0,6"
                               VerticalAlignment="Bottom" />
                </StackPanel>
                <TextBlock Text="共有相手と自分のPC内部のフォルダーを共有します"
                           Foreground="#E7EFE8"
                           Margin="0,6,0,0"
                           FontSize="14" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="28" Background="#FFFEFA">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border x:Name="ClosedShopPanel"
                    Grid.Row="0"
                    BorderBrush="#D8D2C3"
                    BorderThickness="1"
                    CornerRadius="8"
                    Background="#FFFEFA"
                    Padding="20">
                <StackPanel>
                    <TextBlock Text="自分の共有"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#2F2A22" />

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="MyShopTextBox"
                                 Grid.Column="0"
                                 Height="34"
                                 VerticalContentAlignment="Center"
                                 IsReadOnly="True"
                                 Background="#FFF8CC"
                                 FontSize="13" />
                        <Button x:Name="BrowseButton"
                                Grid.Column="2"
                                Content="共有指定"
                                Width="88"
                                Height="34"
                                Click="BrowseButton_Click" />
                        <Button x:Name="ShopDoorButton"
                                Grid.Column="4"
                                Content="共有開始"
                                Width="100"
                                Height="34"
                                Click="ShopDoorButton_Click" />
                        <Button Grid.Column="6"
                                Content="エクスプローラ"
                                Width="120"
                                Height="34"
                                Click="OpenFolderButton_Click" />
                    </Grid>

                    <TextBlock x:Name="StatusTextBlock"
                               Text="共有する場所を選んでください。"
                               Margin="0,10,0,0"
                               FontSize="13"
                               Foreground="#5F5A50" />
                </StackPanel>
            </Border>

            <Border x:Name="OpenShopPanel"
                    Grid.Row="0"
                    BorderBrush="#A8C9BA"
                    BorderThickness="1"
                    CornerRadius="8"
                    Background="#F8FCF8"
                    Padding="20,14"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="自分の共有"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#243B35" />
                        <TextBlock x:Name="OpenStatusTextBlock"
                                   Text=""
                                   FontSize="13"
                                   Foreground="#52645E"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip=""
                                   Margin="0,2,0,0" />
                    </StackPanel>

                    <Button x:Name="UserListButton"
                            Grid.Column="2"
                            Content="ユーザー一覧"
                            Width="110"
                            Height="32"
                            Click="UserListButton_Click" />
                    <Button x:Name="OpenStateCloseButton"
                            Grid.Column="4"
                            Content="共有を閉じる"
                            Width="110"
                            Height="32"
                            Click="ShopDoorButton_Click" />
                    <Button Grid.Column="6"
                            Content="エクスプローラー"
                            Width="116"
                            Height="32"
                            Click="OpenFolderButton_Click" />
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

            <Border x:Name="ShopContentsBorder"
                    Grid.Column="0"
                    BorderBrush="#D8D2C3"
                    BorderThickness="1"
                    CornerRadius="8"
                    Background="#FFFEFA"
                    Padding="20"
                    SizeChanged="ShopContentsBorder_SizeChanged">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" LastChildFill="True">
                        <StackPanel DockPanel.Dock="Left"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,16,0">
                            <Button x:Name="BackButton"
                                    Content="戻る"
                                    Width="70"
                                    Height="30"
                                    IsEnabled="False"
                                    Click="BackButton_Click" />
                            <Button x:Name="ForwardButton"
                                    Content="進む"
                                    Width="70"
                                    Height="30"
                                    Margin="8,0,0,0"
                                    IsEnabled="False"
                                    Click="ForwardButton_Click" />
                            <Button x:Name="TopButton"
                                    Content="トップ"
                                    Width="70"
                                    Height="30"
                                    Margin="8,0,0,0"
                                    Click="TopButton_Click" />
                        </StackPanel>

                        <Button x:Name="RefreshButton"
                                DockPanel.Dock="Right"
                                Style="{StaticResource IconButtonStyle}"
                                ToolTip="最新の状態に更新"
                                Click="RefreshButton_Click">
                            <TextBlock Text="&#xE72C;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="12" />
                        </Button>

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,6,0">
                            <ComboBox x:Name="ExplorerTargetComboBox"
                                      DisplayMemberPath="Label"
                                      MinWidth="136"
                                      Height="32"
                                      Padding="4,0,2,0"
                                      FontSize="16"
                                      FontWeight="SemiBold"
                                      VerticalContentAlignment="Center"
                                      SelectionChanged="ExplorerTargetComboBox_SelectionChanged" />
                            <TextBlock x:Name="CurrentPathTextBlock"
                                       Text=""
                                       FontSize="13"
                                       Foreground="#3D3833"
                                       VerticalAlignment="Bottom"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="10,0,0,2"
                                       MaxWidth="420" />
                        </StackPanel>
                    </DockPanel>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                        <Canvas x:Name="RubberBandCanvas" IsHitTestVisible="False" Panel.ZIndex="10">
                            <Rectangle x:Name="RubberBandRect"
                                       Visibility="Collapsed"
                                       Fill="#1A0078D4"
                                       Stroke="#0078D4"
                                       StrokeThickness="1" />
                        </Canvas>
                        <ListView x:Name="ShopItemsListView"
                                  ItemsSource="{Binding ShopItems}"
                                  ItemContainerStyle="{StaticResource ShopListViewItemStyle}"
                                  SelectionMode="Extended"
                                  AllowDrop="True"
                                  DragEnter="ShopItemsListView_DragEnter"
                                  DragOver="ShopItemsListView_DragEnter"
                                  DragLeave="ShopItemsListView_DragLeave"
                                  Drop="ShopItemsListView_Drop"
                                  GiveFeedback="ShopItemsListView_GiveFeedback"
                                  MouseDoubleClick="ShopItemsListView_MouseDoubleClick"
                                  PreviewMouseLeftButtonDown="ShopItemsListView_PreviewMouseLeftButtonDown"
                                  MouseMove="ShopItemsListView_MouseMove"
                                  PreviewMouseRightButtonDown="ShopItemsListView_PreviewMouseRightButtonDown"
                                  MouseLeftButtonUp="ShopItemsListView_MouseLeftButtonUp"
                                  PreviewKeyDown="ShopItemsListView_PreviewKeyDown"
                                  SizeChanged="ShopItemsListView_SizeChanged"
                                  SelectionChanged="ShopItemsListView_SelectionChanged"
                                  GridViewColumnHeader.Click="ShopItemsListView_HeaderClick"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ToolTip="ダブルクリックで中に入るか、開きます。">
                            <ListView.ContextMenu>
                                <ContextMenu Opened="ShopItemsContextMenu_Opened">
                                    <MenuItem x:Name="MoveShopItemMenuItem"
                                              Header="リネーム"
                                              Click="RenameShopItemMenuItem_Click" />
                                    <MenuItem x:Name="MoveToFolderMenuItem"
                                              Header="フォルダーへ移動"
                                              Click="MoveToFolderMenuItem_Click" />
                                    <MenuItem x:Name="HoldShopItemMenuItem"
                                              Header="保留にしまう"
                                              Click="HoldShopItemMenuItem_Click" />
                                    <MenuItem x:Name="DeleteShopItemMenuItem"
                                              Header="削除"
                                              Click="DeleteShopItemMenuItem_Click" />
                                    <Separator x:Name="AddFolderSeparator" />
                                    <MenuItem x:Name="AddFolderMenuItem"
                                              Header="フォルダー追加"
                                              Click="AddFolderMenuItem_Click" />
                                </ContextMenu>
                            </ListView.ContextMenu>
                            <ListView.View>
                                <GridView ColumnHeaderContainerStyle="{StaticResource ShopColumnHeaderStyle}">
                                    <GridViewColumn x:Name="NameColumn"
                                                    Width="360">
                                        <GridViewColumn.Header>
                                            <GridViewColumnHeader x:Name="NameColumnHeader"
                                                                  Content="名前"
                                                                  Tag="Name" />
                                        </GridViewColumn.Header>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Viewbox Width="15"
                                                             Height="15"
                                                             Margin="0,0,8,0"
                                                             VerticalAlignment="Center"
                                                             Stretch="Uniform">
                                                        <Path Data="{Binding IconPathData}"
                                                              Fill="{Binding IconFillBrush}"
                                                              Stroke="{Binding IconStrokeBrush}"
                                                              StrokeThickness="1.8"
                                                              StrokeLineJoin="Round"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round" />
                                                    </Viewbox>
                                                    <TextBlock Text="{Binding Name}"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBox VerticalAlignment="Center"
                                                             Padding="2,1"
                                                             BorderThickness="1"
                                                             BorderBrush="#B0413E"
                                                             MinWidth="80"
                                                             IsVisibleChanged="InlineRenameBox_IsVisibleChanged"
                                                             KeyDown="InlineRenameBox_KeyDown"
                                                             LostFocus="InlineRenameBox_LostFocus">
                                                        <TextBox.Text>
                                                            <Binding Path="Name" Mode="OneTime" />
                                                        </TextBox.Text>
                                                        <TextBox.Style>
                                                            <Style TargetType="TextBox">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBox.Style>
                                                    </TextBox>
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn x:Name="ShareStatusColumn"
                                                    Width="86">
                                        <GridViewColumn.Header>
                                            <GridViewColumnHeader x:Name="ShareStatusColumnHeader"
                                                                  Content="共有状況"
                                                                  Foreground="#B0413E"
                                                                  Tag="ShareStatus" />
                                        </GridViewColumn.Header>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding ShareStatusText}"
                                                        Tag="{Binding}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Padding="10,2"
                                                        Background="Transparent"
                                                        BorderBrush="Transparent"
                                                        BorderThickness="0"
                                                        Foreground="#B0413E"
                                                        Cursor="Hand"
                                                        Click="ShareStatusButton_Click"
                                                        ToolTip="このアイテムの許可を指定" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn x:Name="KindColumn"
                                                    Width="80"
                                                    DisplayMemberBinding="{Binding KindText}">
                                        <GridViewColumn.Header>
                                            <GridViewColumnHeader x:Name="KindColumnHeader"
                                                                  Content="種類"
                                                                  Tag="Kind" />
                                        </GridViewColumn.Header>
                                    </GridViewColumn>
                                    <GridViewColumn x:Name="UpdatedAtColumn"
                                                    Width="140"
                                                    DisplayMemberBinding="{Binding UpdatedAtText}">
                                        <GridViewColumn.Header>
                                            <GridViewColumnHeader x:Name="UpdatedAtColumnHeader"
                                                                  Content="更新日時"
                                                                  Tag="UpdatedAt" />
                                        </GridViewColumn.Header>
                                    </GridViewColumn>
                                    <GridViewColumn x:Name="SizeColumn"
                                                    Width="100">
                                        <GridViewColumn.Header>
                                            <GridViewColumnHeader x:Name="SizeColumnHeader"
                                                                  Content="サイズ"
                                                                  Tag="Size" />
                                        </GridViewColumn.Header>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding SizeText}"
                                                           HorizontalAlignment="Right" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <Border x:Name="DragHintBorder"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,34,12,0"
                                Padding="10,6"
                                Background="#F8FBFF"
                                BorderBrush="#B8D8FF"
                                BorderThickness="1"
                                CornerRadius="4"
                                IsHitTestVisible="False"
                                Visibility="Collapsed">
                            <TextBlock x:Name="DragHintTextBlock"
                                       Text="移動先のフォルダーに重ねて離すと移動します"
                                       Foreground="#1F4E79"
                                       FontSize="12" />
                        </Border>
                        </Grid>

                        <Border x:Name="SelectionActionBar"
                                Grid.Row="1"
                                Visibility="Collapsed"
                                Background="#EDE8DF"
                                BorderBrush="#D8D2C3"
                                BorderThickness="0,1,0,0"
                                Padding="6,2,6,2"
                                Margin="0,4,0,0">
                            <DockPanel LastChildFill="False">
                                <Button x:Name="DeselectAllButton"
                                        DockPanel.Dock="Left"
                                        Content="✕"
                                        ToolTip="選択を解除"
                                        Width="16"
                                        Height="16"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        FontSize="9"
                                        Cursor="Hand"
                                        VerticalAlignment="Center"
                                        Click="DeselectAllButton_Click" />
                                <TextBlock x:Name="SelectionCountText"
                                           DockPanel.Dock="Left"
                                           Text=""
                                           FontSize="10"
                                           VerticalAlignment="Center"
                                           Margin="4,0,14,0"
                                           Foreground="#3D3833" />
                                <Button x:Name="ActionBarRenameButton"
                                        DockPanel.Dock="Left"
                                        Content="名前変更"
                                        Height="20"
                                        Padding="10,0"
                                        FontSize="10"
                                        Margin="0,0,8,0"
                                        Visibility="Collapsed"
                                        Click="ActionBarRenameButton_Click" />
                                <Button x:Name="ActionBarMoveButton"
                                        DockPanel.Dock="Left"
                                        Content="移動"
                                        Height="20"
                                        Padding="10,0"
                                        FontSize="10"
                                        Margin="0,0,8,0"
                                        Visibility="Collapsed"
                                        Click="ActionBarMoveButton_Click" />
                                <Button x:Name="ActionBarHoldButton"
                                        DockPanel.Dock="Left"
                                        Content="保留"
                                        Height="20"
                                        Padding="10,0"
                                        FontSize="10"
                                        Margin="0,0,8,0"
                                        Visibility="Collapsed"
                                        Click="ActionBarHoldButton_Click" />
                                <Button x:Name="ActionBarPlaceButton"
                                        DockPanel.Dock="Left"
                                        Content="お店に戻す"
                                        Height="20"
                                        Padding="10,0"
                                        FontSize="10"
                                        Margin="0,0,8,0"
                                        Visibility="Collapsed"
                                        Click="ActionBarPlaceButton_Click" />
                                <Button x:Name="ActionBarDeleteButton"
                                        DockPanel.Dock="Left"
                                        Content="削除"
                                        Height="20"
                                        Padding="10,0"
                                        FontSize="10"
                                        Visibility="Collapsed"
                                        Click="ActionBarDeleteButton_Click" />
                            </DockPanel>
                        </Border>
                    </Grid>

                    <DockPanel Grid.Row="3"
                               Margin="0,8,2,0"
                               LastChildFill="False">
                        <CheckBox x:Name="SizeCalcCheckBox"
                                  DockPanel.Dock="Right"
                                  Content="容量計算"
                                  FontSize="12"
                                  Foreground="#4B5563"
                                  VerticalAlignment="Center"
                                  Checked="SizeCalcCheckBox_Changed"
                                  Unchecked="SizeCalcCheckBox_Changed" />
                        <StackPanel Orientation="Horizontal"
                                    DockPanel.Dock="Left"
                                    VerticalAlignment="Center">
                            <TextBlock Text="検索"
                                       FontSize="12"
                                       Foreground="#4B5563"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0" />
                            <TextBox x:Name="SearchTextBox"
                                     Width="320"
                                     Height="23"
                                     VerticalContentAlignment="Center"
                                     FontSize="12"
                                     KeyDown="SearchTextBox_KeyDown" />
                        </StackPanel>
                    </DockPanel>
                </Grid>
            </Border>

            <Border x:Name="SidebarBorder"
                    Grid.Column="1"
                    Width="280"
                    Margin="12,0,0,0"
                    BorderBrush="#D8D2C3"
                    BorderThickness="1"
                    CornerRadius="8"
                    Background="#FFFEFA"
                    Padding="14"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="お店の周りの人"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#2F2A22" />
                    <ListView Grid.Row="2"
                              x:Name="SidebarListView"
                              ItemsSource="{Binding SidebarItems}"
                              BorderThickness="0"
                              Background="Transparent"
                              MouseDoubleClick="SidebarListView_MouseDoubleClick"
                              ToolTip="ダブルクリックでお店を開きます。">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2,4">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontSize="13"
                                               FontWeight="Medium"
                                               Foreground="#2F2A22" />
                                    <TextBlock Text="{Binding StatusLabel}"
                                               FontSize="11"
                                               Foreground="#6F675C" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock Grid.Row="3"
                               x:Name="SidebarStatusTextBlock"
                               Text=""
                               FontSize="11"
                               Foreground="#52645E"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap" />
                </Grid>
            </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="#E8E1D2" Padding="28,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="160" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="FooterMessageTextBlock"
                           Grid.Column="0"
                           Text="共有相手の気配を受け取ります"
                           Foreground="#5D5448"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           FontSize="12" />
                <Button Grid.Column="2"
                        x:Name="AccessHistoryButton"
                        Content="アクセス履歴"
                        Width="92"
                        Height="26"
                        Click="AccessHistoryButton_Click" />
                <Button Grid.Column="4"
                        x:Name="UpdateHistoryButton"
                        Content="更新履歴"
                        Width="80"
                        Height="26"
                        Click="UpdateHistoryButton_Click" />
                <Button Grid.Column="6"
                        x:Name="NotificationHistoryButton"
                        Content="通知履歴"
                        Width="80"
                        Height="26"
                        Click="NotificationHistoryButton_Click" />
                <StackPanel Grid.Column="8"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="通知:"
                               VerticalAlignment="Center"
