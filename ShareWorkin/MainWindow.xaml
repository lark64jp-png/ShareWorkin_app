<Window x:Class="ShareWorkin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ShareWorkin"
        Height="520"
        Width="860"
        MinHeight="420"
        MinWidth="680"
        Background="#F5F7FA"
        FontFamily="Yu Gothic UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1F2937" Padding="28,22">
            <StackPanel>
                <TextBlock Text="ShareWorkin"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock Text="共有フォルダー便利アプリ 1.01"
                           Foreground="#D1D5DB"
                           Margin="0,6,0,0"
                           FontSize="14" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#D7DEE8"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="22">
                <StackPanel>
                    <TextBlock Text="インストール確認用の初期画面"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#111827" />
                    <TextBlock Text="この版では、アプリをWindowsアプリとしてインストールし、スタートメニューから起動できるところまでを確認します。"
                               TextWrapping="Wrap"
                               Margin="0,12,0,0"
                               FontSize="14"
                               Foreground="#374151"
                               LineHeight="22" />
                    <TextBlock Text="共有フォルダー管理、通知、権限設定は次回以降の小さな仕様に分けて追加します。"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0"
                               FontSize="14"
                               Foreground="#374151"
                               LineHeight="22" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#D7DEE8"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="22">
                <StackPanel>
                    <TextBlock Text="Version"
                               FontSize="13"
                               Foreground="#6B7280" />
                    <TextBlock Text="1.01"
                               Margin="0,4,0,18"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="#111827" />
                    <Button Content="閉じる"
                            Width="120"
                            Height="34"
                            HorizontalAlignment="Left"
                            Click="CloseButton_Click" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#E5E7EB" Padding="28,12">
            <TextBlock Text="ShareWorkin - first install package"
                       Foreground="#4B5563"
                       FontSize="12" />
        </Border>
    </Grid>
</Window>
