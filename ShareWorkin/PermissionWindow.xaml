<Window x:Class="ShareWorkin.PermissionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="許可指定"
        Height="460"
        Width="640"
        MinHeight="420"
        MinWidth="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="#FFFEFA"
        FontFamily="Yu Gothic UI">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="6" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="許可指定"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#2F2A22" />
            <TextBlock Grid.Column="2"
                       x:Name="TargetItemTextBlock"
                       Text=""
                       FontSize="13"
                       Foreground="#52645E"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Bottom"
                       TextTrimming="CharacterEllipsis" />
        </Grid>

        <WrapPanel Grid.Row="2">
            <RadioButton x:Name="ReadWriteRadio"
                         Content="読み書き"
                         GroupName="AccessLevel"
                         IsChecked="True"
                         Checked="AccessLevelRadio_Checked"
                         FontSize="13"
                         Foreground="#6F675C"
                         Margin="0,0,16,4" />
            <RadioButton x:Name="ReadOnlyRadio"
                         Content="読みのみ"
                         GroupName="AccessLevel"
                         IsChecked="False"
                         Checked="AccessLevelRadio_Checked"
                         FontSize="13"
                         Foreground="#6F675C"
                         Margin="0,0,16,4" />
            <RadioButton x:Name="SharedOffRadio"
                         Content="共有OFF"
                         GroupName="AccessLevel"
                         IsChecked="False"
                         Checked="AccessLevelRadio_Checked"
                         FontSize="13"
                         Foreground="#6F675C"
                         Margin="0,0,16,4" />
        </WrapPanel>

        <TextBlock Grid.Row="4"
                   x:Name="HintTextBlock"
                   FontSize="12"
                   Foreground="#4B5563"
                   TextWrapping="Wrap" />

        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="60" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="#D8D2C3"
                    BorderThickness="1"
                    CornerRadius="6"
                    Background="White">
                <Grid>
                    <ListBox x:Name="AllowedListBox"
                             BorderThickness="0"
                             Background="Transparent"
                             SelectionMode="Extended"
                             MouseDoubleClick="AllowedListBox_MouseDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="13" Padding="6,4" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock x:Name="EveryoneOverlay"
                               Text="全員"
                               FontSize="34"
                               FontWeight="SemiBold"
                               Foreground="#C8C2B5"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False" />
                </Grid>
            </Border>

            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <Button Content="←"
                        x:Name="MoveLeftButton"
                        Width="36"
                        Height="32"
                        Margin="0,4"
                        Click="MoveLeftButton_Click"
                        ToolTip="未設定 → 許可" />
                <Button Content="→"
                        x:Name="MoveRightButton"
                        Width="36"
                        Height="32"
                        Margin="0,4"
                        Click="MoveRightButton_Click"
                        ToolTip="許可 → 未設定" />
            </StackPanel>

            <Border Grid.Column="2"
                    BorderBrush="#D8D2C3"
                    BorderThickness="1"
                    CornerRadius="6"
                    Background="White">
                <Grid>
                    <ListBox x:Name="UnsetListBox"
                             BorderThickness="0"
                             Background="Transparent"
                             SelectionMode="Extended"
                             MouseDoubleClick="UnsetListBox_MouseDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="13" Padding="6,4" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock x:Name="UnsetOverlay"
                               Text="全員を設定済み"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#C8C2B5"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False" />
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="8"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <TextBlock x:Name="StatusTextBlock"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="#4B5563"
                       Margin="0,0,12,0" />
            <Button Content="OK"
                    Width="84"
                    Height="32"
                    IsDefault="True"
                    Margin="0,0,8,0"
                    Click="OkButton_Click" />
            <Button Content="キャンセル"
                    Width="96"
                    Height="32"
                    IsCancel="True"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
