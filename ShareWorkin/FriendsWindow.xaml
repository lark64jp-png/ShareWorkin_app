<Window x:Class="ShareWorkin.FriendsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="お友達"
        Height="480"
        Width="640"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA"
        FontFamily="Yu Gothic UI">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="6" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="お友達"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="#111827" />
        <TextBlock Grid.Row="2"
                   Text="ダブルクリックでお友達のお店を開きます。右側のボタンで取り込み・名前変更・削除ができます。"
                   FontSize="12"
                   Foreground="#4B5563"
                   TextWrapping="Wrap" />

        <Border Grid.Row="4"
                BorderBrush="#D7DEE8"
                BorderThickness="1"
                CornerRadius="6"
                Background="White">
            <ListView x:Name="FriendsListView"
                      BorderThickness="0"
                      MouseDoubleClick="FriendsListView_MouseDoubleClick">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="呼び名" Width="160" DisplayMemberBinding="{Binding DisplayName}" />
                        <GridViewColumn Header="お店" Width="160" DisplayMemberBinding="{Binding ShareName}" />
                        <GridViewColumn Header="場所" Width="200" DisplayMemberBinding="{Binding UncPath}" />
                        <GridViewColumn Header="権限" Width="80" DisplayMemberBinding="{Binding AccessLabel}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <TextBlock x:Name="StatusTextBlock"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="#4B5563"
                       Margin="0,0,12,0" />
            <Button Content="招待を取り込む"
                    Width="120"
                    Height="32"
                    Margin="0,0,8,0"
                    Click="ImportButton_Click" />
            <Button x:Name="OpenButton"
                    Content="お店を開く"
                    Width="100"
                    Height="32"
                    Margin="0,0,8,0"
                    Click="OpenButton_Click" />
            <Button x:Name="RenameButton"
                    Content="名前を変える"
                    Width="100"
                    Height="32"
                    Margin="0,0,8,0"
                    Click="RenameButton_Click" />
            <Button x:Name="RemoveButton"
                    Content="削除"
                    Width="64"
                    Height="32"
                    Margin="0,0,8,0"
                    Click="RemoveButton_Click" />
            <Button Content="閉じる"
                    Width="84"
                    Height="32"
                    IsCancel="True"
                    Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
