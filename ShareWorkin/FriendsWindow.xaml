<Window x:Class="ShareWorkin.FriendsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ユーザー情報"
        Height="640"
        Width="640"
        WindowStartupLocation="CenterOwner"
        Background="#FFFEFA"
        FontFamily="Yu Gothic UI">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- 0: タイトル -->
            <RowDefinition Height="6" />      <!-- 1: spacer -->
            <RowDefinition Height="Auto" />   <!-- 2: サブタイトル -->
            <RowDefinition Height="14" />     <!-- 3: spacer -->
            <RowDefinition Height="Auto" />   <!-- 4: 情報部 -->
            <RowDefinition Height="10" />     <!-- 5: spacer -->
            <RowDefinition Height="Auto" />   <!-- 6: ボタン行 -->
            <RowDefinition Height="4" />      <!-- 7: spacer -->
            <RowDefinition Height="Auto" />   <!-- 8: ステータス行 -->
            <RowDefinition Height="10" />     <!-- 9: spacer -->
            <RowDefinition Height="*" />      <!-- 10: 接続未確定リスト -->
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   x:Name="TitleTextBlock"
                   Text="ピックアップ"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="#2F2A22" />
        <TextBlock Grid.Row="2"
                   x:Name="SubtitleTextBlock"
                   FontSize="12"
                   Foreground="#4B5563"
                   TextWrapping="Wrap" />

        <!-- 情報部 -->
        <Border Grid.Row="4"
                BorderBrush="#D8D2C3"
                BorderThickness="1"
                CornerRadius="6"
                Background="White"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="お友達名 *"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="#2F2A22" />
                <TextBox Grid.Row="0" Grid.Column="2"
                         x:Name="NameTextBox"
                         FontSize="13"
                         Padding="6,4"
                         TextChanged="OnFormChanged" />

                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="共有フォルダー名"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="#4B5563" />
                <TextBlock Grid.Row="2" Grid.Column="2"
                           x:Name="ShareFolderTextBlock"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="#2F2A22" />

                <TextBlock Grid.Row="4" Grid.Column="0"
                           Text="権限"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="#4B5563" />
                <TextBlock Grid.Row="4" Grid.Column="2"
                           x:Name="AccessTextBlock"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="#2F2A22" />

                <TextBlock Grid.Row="6" Grid.Column="0"
                           Text="状態"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="#4B5563" />
                <TextBlock Grid.Row="6" Grid.Column="2"
                           x:Name="PresenceTextBlock"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="#2F2A22" />

                <TextBlock Grid.Row="8" Grid.Column="0"
                           Text="メモ"
                           VerticalAlignment="Top"
                           FontSize="12"
                           Foreground="#4B5563"
                           Margin="0,4,0,0" />
                <TextBox Grid.Row="8" Grid.Column="2"
                         x:Name="MemoTextBox"
                         FontSize="13"
                         Padding="6,4"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="64"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="OnFormChanged" />
            </Grid>
        </Border>

        <!-- ボタン行: 表示中のボタン数に応じて Columns をコードで更新し全幅均等割りを維持 -->
        <UniformGrid x:Name="ButtonPanel"
                     Grid.Row="6"
                     Rows="1"
                     Columns="3">
            <Button Content="再読み込み"
                    Height="32"
                    Margin="0,0,4,0"
                    Click="ReloadButton_Click" />
            <Button x:Name="OpenFolderButton"
                    Content="フォルダーを開く"
                    Height="32"
                    Margin="4,0,4,0"
                    Visibility="Collapsed"
                    Click="OpenFolderButton_Click" />
            <Button x:Name="DeleteButton"
                    Content="削除"
                    Height="32"
                    Margin="4,0,4,0"
                    Visibility="Collapsed"
                    Click="DeleteButton_Click" />
            <Button x:Name="OkButton"
                    Content="確定"
                    Height="32"
                    Margin="4,0,4,0"
                    IsEnabled="False"
                    Click="OkButton_Click" />
            <Button Content="キャンセル"
                    Height="32"
                    Margin="4,0,0,0"
                    IsCancel="True"
                    Click="CancelButton_Click" />
        </UniformGrid>

        <!-- ステータス行（ボタンの下） -->
        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="8"
                   VerticalAlignment="Center"
                   FontSize="12"
                   Foreground="#4B5563" />

        <!-- 接続未確定リスト -->
        <Border Grid.Row="10"
                BorderBrush="#D8D2C3"
                BorderThickness="1"
                CornerRadius="6"
                Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="接続未確定"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#2F2A22"
                           Margin="14,8,14,4" />
                <ListView Grid.Row="1"
                          x:Name="CandidateListView"
                          BorderThickness="0"
                          Background="Transparent"
                          SelectionChanged="CandidateListView_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="ホスト名" Width="200" DisplayMemberBinding="{Binding HostNameLabel}" />
                            <GridViewColumn Header="IP" Width="130" DisplayMemberBinding="{Binding IpLabel}" />
                            <GridViewColumn Header="状態" Width="140" DisplayMemberBinding="{Binding StatusLabel}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Window>
