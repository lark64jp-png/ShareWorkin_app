<Window x:Class="ShareWorkin.FriendsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ピックアップ"
        Height="640"
        Width="640"
        WindowStartupLocation="CenterOwner"
        Background="#FFFEFA"
        FontFamily="Yu Gothic UI">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="6" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   x:Name="TitleTextBlock"
                   Text="ピックアップ"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="#2F2A22" />
        <TextBlock Grid.Row="2"
                   x:Name="SubtitleTextBlock"
                   FontSize="12"
                   Foreground="#4B5563"
                   TextWrapping="Wrap" />

        <!-- 情報部 -->
        <Border Grid.Row="4"
                BorderBrush="#D8D2C3"
                BorderThickness="1"
                CornerRadius="6"
                Background="White"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="お友達名 *"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="#2F2A22" />
                <TextBox Grid.Row="0" Grid.Column="2"
                         x:Name="NameTextBox"
                         FontSize="13"
                         Padding="6,4"
                         TextChanged="OnFormChanged" />

                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="共有フォルダー名"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="#4B5563" />
                <TextBlock Grid.Row="2" Grid.Column="2"
                           x:Name="ShareFolderTextBlock"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="#2F2A22" />

                <TextBlock Grid.Row="4" Grid.Column="0"
                           Text="権限"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="#4B5563" />
                <TextBlock Grid.Row="4" Grid.Column="2"
                           x:Name="AccessTextBlock"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="#2F2A22" />

                <TextBlock Grid.Row="6" Grid.Column="0"
                           Text="状態"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="#4B5563" />
                <TextBlock Grid.Row="6" Grid.Column="2"
                           x:Name="PresenceTextBlock"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="#2F2A22" />

                <TextBlock Grid.Row="8" Grid.Column="0"
                           Text="メモ"
                           VerticalAlignment="Top"
                           FontSize="12"
                           Foreground="#4B5563"
                           Margin="0,4,0,0" />
                <TextBox Grid.Row="8" Grid.Column="2"
                         x:Name="MemoTextBox"
                         FontSize="13"
                         Padding="6,4"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="64"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="OnFormChanged" />
            </Grid>
        </Border>

        <!-- 招待コード(新規登録時のみ表示) -->
        <Border Grid.Row="6"
                x:Name="InviteCodeBorder"
                BorderBrush="#D8D2C3"
                BorderThickness="1"
                CornerRadius="6"
                Background="White"
                Padding="14,10"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="招待コード"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#2F2A22" />
                <TextBlock Text="お友達からもらった招待コードを貼り付けてください。"
                           FontSize="11"
                           Foreground="#6B6358"
                           Margin="0,2,0,6" />
                <TextBox x:Name="InviteCodeTextBox"
                         FontSize="12"
                         Padding="6,4"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="64"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="OnFormChanged" />
            </StackPanel>
        </Border>

        <!-- 未設定 SMB 候補一覧 -->
        <Border Grid.Row="8"
                BorderBrush="#D8D2C3"
                BorderThickness="1"
                CornerRadius="6"
                Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="未設定 SMB 候補(選んで関連付け)"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#2F2A22"
                           Margin="14,8,14,4" />
                <ListView Grid.Row="1"
                          x:Name="CandidateListView"
                          BorderThickness="0"
                          Background="Transparent"
                          SelectionChanged="CandidateListView_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="ホスト名" Width="240" DisplayMemberBinding="{Binding HostNameLabel}" />
                            <GridViewColumn Header="IP" Width="140" DisplayMemberBinding="{Binding IpLabel}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <!-- ボタンバー -->
        <Grid Grid.Row="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusTextBlock"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="#4B5563" />

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal">
                <Button Content="再読み込み"
                        Width="100"
                        Height="32"
                        Margin="0,0,8,0"
                        Click="ReloadButton_Click" />
                <Button x:Name="OpenFolderButton"
                        Content="フォルダーを開く"
                        Width="120"
                        Height="32"
                        Margin="0,0,8,0"
                        Visibility="Collapsed"
                        Click="OpenFolderButton_Click" />
                <Button x:Name="DeleteButton"
                        Content="削除"
                        Width="64"
                        Height="32"
                        Margin="0,0,8,0"
                        Click="DeleteButton_Click" />
                <Button x:Name="OkButton"
                        Content="OK"
                        Width="84"
                        Height="32"
                        Margin="0,0,8,0"
                        IsEnabled="False"
                        Click="OkButton_Click" />
                <Button Content="キャンセル"
                        Width="84"
                        Height="32"
                        IsCancel="True"
                        Click="CancelButton_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
