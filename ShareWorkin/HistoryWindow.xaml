<Window x:Class="ShareWorkin.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="履歴"
        Width="980"
        Height="560"
        MinWidth="860"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F6F1E7">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="*" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock x:Name="TitleTextBlock"
                       Text="履歴"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#2F2A22" />
            <TextBlock x:Name="SubtitleTextBlock"
                       Text="最近の履歴を表で表示します。"
                       FontSize="12"
                       Foreground="#6F675C"
                       Margin="0,6,0,0" />
        </StackPanel>

        <Border Grid.Row="2"
                BorderBrush="#D8D2C3"
                BorderThickness="1"
                CornerRadius="8"
                Background="White"
                Padding="8">
            <DataGrid x:Name="HistoryDataGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      GridLinesVisibility="Horizontal"
                      RowHeaderWidth="0"
                      SelectionMode="Single"
                      SelectionUnit="FullRow">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="日時" Binding="{Binding TimeText}" Width="150" />
                    <DataGridTextColumn Header="相手" Binding="{Binding FriendName}" Width="120" />
                    <DataGridTextColumn Header="方向" Binding="{Binding DirectionText}" Width="90" />
                    <DataGridTextColumn Header="アクション" Binding="{Binding EventTypeText}" Width="110" />
                    <DataGridTextColumn Header="対象" Binding="{Binding TargetName}" Width="180" />
                    <DataGridTextColumn Header="結果" Binding="{Binding OutcomeText}" Width="80" />
                    <DataGridTextColumn Header="補足" Binding="{Binding DetailText}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <DockPanel Grid.Row="4" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left"
                       x:Name="CountTextBlock"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="#6F675C"
                       Text="0 件" />
            <Button DockPanel.Dock="Right"
                    Content="閉じる"
                    Width="100"
                    Height="32"
                    IsCancel="True" />
        </DockPanel>
    </Grid>
</Window>
