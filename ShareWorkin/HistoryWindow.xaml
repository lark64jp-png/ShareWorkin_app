<Window x:Class="ShareWorkin.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="履歴"
        Width="980"
        Height="560"
        MinWidth="860"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F6F1E7">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="4" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="4" />
            <RowDefinition Height="*" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock x:Name="TitleTextBlock"
                       Text="履歴"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#2F2A22" />
            <TextBlock x:Name="SubtitleTextBlock"
                       Text="最近の履歴を表で表示します。"
                       FontSize="12"
                       Foreground="#6F675C"
                       Margin="0,6,0,0" />
            <DockPanel Margin="0,12,0,0" LastChildFill="False">
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="削除基準日時"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="#6F675C" />
                    <TextBox x:Name="DeleteTimestampTextBox"
                             Width="180"
                             Height="28"
                             Margin="8,0,0,0"
                             VerticalContentAlignment="Center"
                             ToolTip="yyyy/MM/dd HH:mm:ss" />
                    <TextBlock Text="yyyy/MM/dd HH:mm:ss"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="#8B8376" />
                </StackPanel>
                <Button DockPanel.Dock="Right"
                        x:Name="DeleteHistoryButton"
                        Content="履歴削除"
                        Width="110"
                        Height="32"
                        Click="DeleteHistoryButton_Click" />
            </DockPanel>
        </StackPanel>

        <Border Grid.Row="2"
                BorderBrush="#D8D2C3"
                BorderThickness="1"
                CornerRadius="8"
                Background="White"
                Padding="8">
            <DataGrid x:Name="HistoryDataGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      GridLinesVisibility="Horizontal"
                      RowHeaderWidth="0"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      SelectionChanged="HistoryDataGrid_SelectionChanged"
                      PreviewKeyDown="HistoryDataGrid_PreviewKeyDown">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="コピー" Click="CopyRowMenuItem_Click" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="日時" Binding="{Binding TimeText}" Width="150" />
                    <DataGridTextColumn Header="ユーザー" Binding="{Binding UserText}" Width="120" />
                    <DataGridTextColumn Header="パス" Binding="{Binding PathText}" Width="220" />
                    <DataGridTextColumn Header="ファイル名" Binding="{Binding FileNameText}" Width="150" />
                    <DataGridTextColumn Header="アクション" Binding="{Binding EventTypeText}" Width="110" />
                    <DataGridTextColumn Header="内容" Binding="{Binding ContentText}" Width="*" />
                    <DataGridTextColumn Header="備考" Binding="{Binding NoteText}" Width="180" />
                    <DataGridTextColumn Header="結果" Binding="{Binding OutcomeText}" Width="80" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="FilterFileName"   Height="16" Margin="0,0,2,0" Padding="2,0" FontSize="10" VerticalContentAlignment="Center" ToolTip="ファイル名" Tag="ファイル名" TextChanged="FilterTextBox_TextChanged" />
            <TextBox Grid.Column="1" x:Name="FilterUser"       Height="16" Margin="0,0,2,0" Padding="2,0" FontSize="10" VerticalContentAlignment="Center" ToolTip="ユーザー"   Tag="ユーザー"   TextChanged="FilterTextBox_TextChanged" />
            <TextBox Grid.Column="2" x:Name="FilterPath"       Height="16" Margin="0,0,2,0" Padding="2,0" FontSize="10" VerticalContentAlignment="Center" ToolTip="パス"       Tag="パス"       TextChanged="FilterTextBox_TextChanged" />
            <TextBox Grid.Column="3" x:Name="FilterAction"     Height="16" Margin="0,0,2,0" Padding="2,0" FontSize="10" VerticalContentAlignment="Center" ToolTip="アクション" Tag="アクション" TextChanged="FilterTextBox_TextChanged" />
            <TextBox Grid.Column="4" x:Name="FilterContent"    Height="16" Margin="0,0,2,0" Padding="2,0" FontSize="10" VerticalContentAlignment="Center" ToolTip="内容"       Tag="内容"       TextChanged="FilterTextBox_TextChanged" />
            <TextBox Grid.Column="5" x:Name="FilterNote"       Height="16" Margin="0,0,2,0" Padding="2,0" FontSize="10" VerticalContentAlignment="Center" ToolTip="備考"       Tag="備考"       TextChanged="FilterTextBox_TextChanged" />
            <Button  Grid.Column="6" x:Name="ClearFilterButton" Content="クリア" Width="54" Height="16" FontSize="10" Padding="0" Click="ClearFilterButton_Click" />
        </Grid>

        <Border Grid.Row="6"
                BorderBrush="#D8D2C3"
                BorderThickness="1"
                CornerRadius="8"
                Background="#FFFDFC"
                Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="ディティール"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#2F2A22" />

                <TextBox Grid.Row="2"
                         x:Name="DetailTextBox"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Background="#FFFDFC"
                         BorderThickness="0"
                         FontFamily="Consolas" />
            </Grid>
        </Border>

        <DockPanel Grid.Row="8" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left"
                       x:Name="CountTextBlock"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="#6F675C"
                       Text="0 件" />
            <Button DockPanel.Dock="Right"
                    Content="閉じる"
                    Width="100"
                    Height="32"
                    IsCancel="True" />
        </DockPanel>
    </Grid>
</Window>
