<Window x:Class="ShareWorkin.IconPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="アイコンを選ぶ"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFFEFA"
        FontFamily="Yu Gothic UI">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="6" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="アイコンを選ぶ"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="#2F2A22" />
        <TextBlock Grid.Row="2"
                   Text="ライブラリから選ぶか、お手持ちの画像（JPG/PNG）をドロップまたは参照で指定できます。"
                   FontSize="12"
                   Foreground="#4B5563"
                   TextWrapping="Wrap" />

        <!-- 左：ライブラリ 4×4 / 右：プレビュー＋素材サイト -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- 左：ライブラリ -->
            <Border Grid.Column="0"
                    BorderBrush="#D8D2C3"
                    BorderThickness="1"
                    CornerRadius="6"
                    Background="White"
                    Padding="8">
                <ItemsControl x:Name="LibraryItems"
                              Width="248"
                              Height="248">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="4" Columns="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Click="LibraryButton_Click"
                                    Tag="{Binding Key}"
                                    Width="56"
                                    Height="56"
                                    Margin="3"
                                    Padding="2"
                                    Background="White"
                                    BorderBrush="{Binding BorderBrush}"
                                    BorderThickness="{Binding BorderThickness}"
                                    Cursor="Hand">
                                <Image Source="{Binding ImageSource}"
                                       Width="40"
                                       Height="40"
                                       Stretch="Uniform" />
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- 右：プレビュー / 素材サイト -->
            <StackPanel Grid.Column="2" Width="200">
                <TextBlock Text="プレビュー"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#2F2A22"
                           Margin="0,0,0,4" />
                <Border x:Name="PreviewDropZone"
                        Width="100"
                        Height="100"
                        HorizontalAlignment="Left"
                        Background="#FAF7F0"
                        BorderBrush="#D8D2C3"
                        BorderThickness="1"
                        CornerRadius="6"
                        AllowDrop="True"
                        DragEnter="PreviewDropZone_DragEnter"
                        DragLeave="PreviewDropZone_DragLeave"
                        Drop="PreviewDropZone_Drop">
                    <Grid>
                        <TextBlock x:Name="DropHintTextBlock"
                                   Text="画像を&#x000a;ドロップ"
                                   FontSize="11"
                                   Foreground="#9B9485"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center" />
                        <Image x:Name="PreviewImage"
                               Stretch="Uniform"
                               Margin="2"
                               Visibility="Collapsed" />
                    </Grid>
                </Border>

                <TextBlock Text="素材サイトを開く"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#2F2A22"
                           Margin="0,12,0,4" />
                <TextBlock Margin="0,1,0,1">
                    <Hyperlink NavigateUri="https://icooon-mono.com/"
                               RequestNavigate="Hyperlink_RequestNavigate">icooon-mono.com</Hyperlink>
                </TextBlock>
                <TextBlock Margin="0,1,0,1">
                    <Hyperlink NavigateUri="https://icon-z.com/"
                               RequestNavigate="Hyperlink_RequestNavigate">icon-z.com</Hyperlink>
                </TextBlock>
                <TextBlock Margin="0,1,0,1">
                    <Hyperlink NavigateUri="https://icon-pit.com/pictogram/33828"
                               RequestNavigate="Hyperlink_RequestNavigate">icon-pit.com（ピクトグラム）</Hyperlink>
                </TextBlock>
            </StackPanel>
        </Grid>

        <!-- フッター: 左 [参照][クリア] / 右 [確定][閉じる] -->
        <DockPanel Grid.Row="6" LastChildFill="False">
            <UniformGrid DockPanel.Dock="Left" Rows="1" Columns="2" Width="180">
                <Button Content="参照…"
                        Height="32"
                        Margin="0,0,4,0"
                        Click="BrowseButton_Click" />
                <Button Content="クリア"
                        Height="32"
                        Margin="4,0,0,0"
                        Click="ClearButton_Click" />
            </UniformGrid>
            <UniformGrid DockPanel.Dock="Right" Rows="1" Columns="2" Width="180">
                <Button x:Name="ConfirmButton"
                        Content="確定"
                        Height="32"
                        Margin="0,0,4,0"
                        IsEnabled="False"
                        Click="ConfirmButton_Click" />
                <Button Content="閉じる"
                        Height="32"
                        Margin="4,0,0,0"
                        IsCancel="True"
                        Click="CancelButton_Click" />
            </UniformGrid>
        </DockPanel>
    </Grid>
</Window>
