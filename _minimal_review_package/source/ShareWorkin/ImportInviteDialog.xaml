<Window x:Class="ShareWorkin.ImportInviteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="招待を取り込む"
        Height="420"
        Width="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#F5F7FA"
        FontFamily="Yu Gothic UI">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="6" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="6" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="招待を取り込む"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="#111827" />
        <TextBlock Grid.Row="2"
                   Text="お友達からもらった招待コードを下に貼り付けてください。"
                   FontSize="12"
                   Foreground="#4B5563"
                   TextWrapping="Wrap" />

        <Border Grid.Row="4"
                BorderBrush="#D7DEE8"
                BorderThickness="1"
                CornerRadius="6"
                Background="White"
                Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="TokenTextBox"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         FontFamily="Consolas"
                         FontSize="12"
                         BorderThickness="0"
                         Background="Transparent" />
            </ScrollViewer>
        </Border>

        <TextBlock Grid.Row="6"
                   Text="お友達への呼び方(あとから変えられます)"
                   FontSize="12"
                   Foreground="#4B5563" />
        <TextBox x:Name="DisplayNameTextBox"
                 Grid.Row="8"
                 Height="32"
                 VerticalContentAlignment="Center"
                 FontSize="13" />

        <StackPanel Grid.Row="10"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <TextBlock x:Name="StatusTextBlock"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="#B91C1C"
                       Margin="0,0,12,0" />
            <Button x:Name="ImportButton"
                    Content="取り込む"
                    Width="100"
                    Height="32"
                    IsDefault="True"
                    Margin="0,0,8,0"
                    Click="ImportButton_Click" />
            <Button Content="キャンセル"
                    Width="84"
                    Height="32"
                    IsCancel="True"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
