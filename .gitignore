# Project management root exclusions
backup/
.codex/
.claude/
_chatgpt_review_staging/
_minimal_review_package/

# _works is tracked by default, except for Trash and generated artifacts
_works/Trash/
_works/**/*.zip
_works/**/*.exe
_works/**/*.msi
_works/**/*.log
_works/**/*.tmp
_works/**/*.7z
_works/**/*.rar
_works/**/*.iso
_works/**/*.bin
_works/**/*.dmp
_works/**/*.pdb

# Build output
**/bin/
**/obj/
repo/build/
repo/dist/

# Visual Studio / Rider
.vs/
.idea/
**/.vs/
**/.idea/
*.user
*.suo
*.userosscache
*.sln.docstates

# .NET
TestResults/
*.nupkg
*.snupkg

# Installer compiler temporary files
*.tmp

# Managed artifacts under repo/builds: keep docs and hash text only
repo/builds/**
!repo/builds/
!repo/builds/**/*.md
!repo/builds/**/*SHA256*.txt

# Build artifacts and runtime installer kept out of source history
repo/ShareWorkin_v*_install*.exe
repo/ShareWorkin_v*_Setup.zip
repo/ShareWorkin_v*_SHA256*.txt
repo/ChatGPT相談用_*.zip
repo/windowsdesktop-runtime-*.exe

# OS files
Thumbs.db
Desktop.ini
