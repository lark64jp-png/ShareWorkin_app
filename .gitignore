# Project management root exclusions
backup/
.codex/
.claude/
_chatgpt_review_staging/
_minimal_review_package/

# _works stays excluded by default; only curated sync targets are tracked
_works/**
!_works/

# GitHub sync documents
!_works/GitHub同期/
!_works/GitHub同期/**

# Exclude generated/binary/log artifacts even under GitHub同期
_works/GitHub同期/**/*.zip
_works/GitHub同期/**/*.exe
_works/GitHub同期/**/*.msi
_works/GitHub同期/**/*.log
_works/GitHub同期/**/*.tmp
_works/GitHub同期/**/*.7z
_works/GitHub同期/**/*.rar
_works/GitHub同期/**/*.iso
_works/GitHub同期/**/*.bin
_works/GitHub同期/**/*.dmp
_works/GitHub同期/**/*.pdb

# Sync runner scripts only
!_works/同期実行/
_works/同期実行/**
!_works/同期実行/*.bat
!_works/同期実行/*.ps1

# Trash always stays out of Git
_works/Trash/

# Build output
**/bin/
**/obj/
repo/build/
repo/dist/

# Visual Studio / Rider
.vs/
.idea/
**/.vs/
**/.idea/
*.user
*.suo
*.userosscache
*.sln.docstates

# .NET
TestResults/
*.nupkg
*.snupkg

# Installer compiler temporary files
*.tmp

# Managed artifacts under repo/builds: keep docs and hash text only
repo/builds/**
!repo/builds/
!repo/builds/**/*.md
!repo/builds/**/*SHA256*.txt

# Build artifacts and runtime installer kept out of source history
repo/ShareWorkin_v*_install*.exe
repo/ShareWorkin_v*_Setup.zip
repo/ShareWorkin_v*_SHA256*.txt
repo/ChatGPT相談用_*.zip
repo/windowsdesktop-runtime-*.exe

# OS files
Thumbs.db
Desktop.ini
