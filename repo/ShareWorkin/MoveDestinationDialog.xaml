<Window x:Class="ShareWorkin.MoveDestinationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="どこへ移しますか?"
        Height="420"
        Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="#F5F7FA"
        FontFamily="Yu Gothic UI">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="どこへ移しますか?"
                   FontSize="14"
                   Foreground="#111827" />

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#D7DEE8"
                BorderThickness="1"
                CornerRadius="6">
            <TreeView x:Name="DestinationTreeView"
                      BorderThickness="0"
                      Background="Transparent"
                      SelectedItemChanged="DestinationTreeView_SelectedItemChanged" />
        </Border>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="やめる"
                    Width="84"
                    Height="30"
                    IsCancel="True"
                    Click="CancelButton_Click"
                    Margin="0,0,8,0" />
            <Button x:Name="MoveButton"
                    Content="移す"
                    Width="84"
                    Height="30"
                    IsDefault="True"
                    IsEnabled="False"
                    Click="MoveButton_Click" />
        </StackPanel>
    </Grid>
</Window>
