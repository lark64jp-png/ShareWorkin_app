<Window x:Class="ShareWorkin.InteractionActionConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="通知付き操作の確認"
        Height="430"
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="#F5F7FA"
        FontFamily="Yu Gothic UI">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="この操作を実行すると、相手に通知します。"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="#111827" />

        <Border Grid.Row="2"
                Padding="12"
                Background="White"
                BorderBrush="#D7DEE8"
                BorderThickness="1"
                CornerRadius="6">
            <StackPanel>
                <TextBlock x:Name="ActionSummaryTextBlock"
                           TextWrapping="Wrap"
                           Foreground="#111827" />
                <TextBlock x:Name="FriendSummaryTextBlock"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"
                           Foreground="#374151" />
            </StackPanel>
        </Border>

        <Border Grid.Row="4"
                Padding="12"
                Background="White"
                BorderBrush="#D7DEE8"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="対象"
                           FontWeight="SemiBold"
                           Foreground="#111827" />

                <ListBox x:Name="TargetsListBox"
                         Grid.Row="2"
                         BorderThickness="1"
                         BorderBrush="#E5E7EB"
                         Background="#FCFCFD" />

                <StackPanel Grid.Row="4">
                    <TextBlock Text="メッセージを添えられます。空でもかまいません。"
                               Foreground="#4B5563" />
                    <TextBox x:Name="MessageTextBox"
                             Margin="0,8,0,0"
                             Height="84"
                             VerticalContentAlignment="Top"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock Grid.Row="6"
                   Text="OK を押した時点で操作と通知内容を確定します。"
                   Foreground="#6B7280" />

        <StackPanel Grid.Row="8"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="キャンセル"
                    Width="92"
                    Height="30"
                    IsCancel="True"
                    Click="CancelButton_Click"
                    Margin="0,0,8,0" />
            <Button Content="実行して通知"
                    Width="110"
                    Height="30"
                    IsDefault="True"
                    Click="ConfirmButton_Click" />
        </StackPanel>
    </Grid>
</Window>
